generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum WorktreeStage {
  IDEA
  SPEC
  PRD
  PLAN
  EXECUTING
  DONE
}

enum ArtifactType {
  SPEC
  PRD
}

enum ArtifactStatus {
  DRAFT
  REVIEW
  APPROVED
}

enum PlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum PhaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Project {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  basePath    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  worktrees   Worktree[]
}

model Worktree {
  id        String         @id @default(uuid())
  projectId String
  name      String         @unique
  path      String
  branch    String
  stage     WorktreeStage  @default(IDEA)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifacts Artifact[]
  plan      Plan?

  @@index([projectId])
}

model Artifact {
  id          String         @id @default(uuid())
  worktreeId  String
  type        ArtifactType
  filePath    String
  title       String
  content     String?
  status      ArtifactStatus @default(DRAFT)
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  worktree    Worktree @relation(fields: [worktreeId], references: [id], onDelete: Cascade)

  @@index([worktreeId])
  @@unique([worktreeId, filePath])
}

model Plan {
  id                  String     @id @default(uuid())
  worktreeId          String     @unique
  title               String
  description         String?
  architecturalNotes  String?
  status              PlanStatus @default(DRAFT)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  worktree  Worktree @relation(fields: [worktreeId], references: [id], onDelete: Cascade)
  phases    Phase[]
}

model Phase {
  id                  String      @id @default(uuid())
  planId              String
  name                String
  description         String?
  order               Int
  status              PhaseStatus @default(PENDING)
  acceptanceCriteria  String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([planId])
}

model Task {
  id          String     @id @default(uuid())
  phaseId     String
  subject     String
  description String?
  status      TaskStatus @default(PENDING)
  order       Int
  agentId     String?
  result      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  phase    Phase                @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  criteria AcceptanceCriterion[]

  @@index([phaseId])
  @@index([status])
}

model AcceptanceCriterion {
  id        String   @id @default(uuid())
  taskId    String
  text      String
  checked   Boolean  @default(false)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, order])
}
