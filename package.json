{
  "name": "status-manager",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "sm": "./cli/index.js"
  },
  "scripts": {
    "dev": "next dev --port 4000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
